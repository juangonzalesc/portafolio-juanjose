---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: 'es' | 'en';
}

const {
  lang = 'es',
  title = lang === 'es' ? "Juan José Gonzales Centurión | Especialista en SEO & Web" : "Juan José Gonzales Centurión | SEO & Web Specialist",
  description = lang === 'es' 
    ? "Especialista en SEO y Marketing Digital con +8 años de experiencia en posicionamiento orgánico, paid media, optimización técnica y estrategia de contenidos. Ayudo a marcas en sectores industriales, e-commerce y salud a dominar Google Search." 
    : "SEO and Digital Marketing Specialist with +8 years of experience in organic positioning, paid media, technical optimization, and content strategy. I help brands in industrial, e-commerce, and health sectors dominate Google Search."
} = Astro.props;

// Schema.org Structured Data for SEO Professional
const schemaData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Juan José Gonzales Centurión",
  "jobTitle": lang === 'es' ? "Especialista en SEO & Web" : "SEO & Web Specialist",
  "description": description,
  "url": Astro.url.href,
  "sameAs": [
    "https://www.linkedin.com/in/juangonzalescenturion/"
  ],
  "knowsAbout": lang === 'es' ? [
    "Search Engine Optimization (SEO)",
    "SEO Técnico",
    "Paid Media",
    "Marketing Digital",
    "WordPress",
    "Core Web Vitals",
    "WooCommerce",
    "Estrategia de Contenidos"
  ] : [
    "Search Engine Optimization (SEO)",
    "Technical SEO",
    "Paid Media",
    "Digital Marketing",
    "WordPress",
    "Core Web Vitals",
    "WooCommerce",
    "Content Strategy"
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "Brandlima"
  }
};

const waText = lang === 'es' 
  ? "Hola%20Juan%20Jos%C3%A9,%20me%20gustar%C3%ADa%20conversar%20sobre%20un%20proyecto." 
  : "Hello%20Juan%20Jos%C3%A9,%20I%20would%20like%20to%20talk%20about%20a%20project.";
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />
    
    <!-- Alternate Language links for SEO (hreflang) -->
    <link rel="alternate" hreflang="es" href={new URL('/', Astro.site || Astro.url.origin).href} />
    <link rel="alternate" hreflang="en" href={new URL('/en/', Astro.site || Astro.url.origin).href} />
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site || Astro.url.origin).href} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/avatar.jpg', Astro.url).href} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL('/avatar.jpg', Astro.url).href} />

    <!-- Google Fonts Preconnect and Load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Prefetch / Preload critical assets -->
    <link 
      rel="preload" 
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" 
      as="style" 
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link 
        href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Poppins:wght@300;400;500;600;700&display=swap" 
        rel="stylesheet" 
      />
    </noscript>

    <!-- Schema.org JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </head>
  <body>
    <!-- Radial Glow Background Effect -->
    <div class="glow-bg"></div>
    
    <slot />

    <!-- Floating WhatsApp Button -->
    <a 
      href={`https://wa.me/51917018796?text=${waText}`} 
      target="_blank" 
      rel="noopener noreferrer" 
      class="floating-whatsapp-btn"
      aria-label={lang === 'es' ? "Chat en WhatsApp" : "Chat on WhatsApp"}
      id="floating-whatsapp"
    >
      <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor">
        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.057 5.283 5.342 0 11.825 0c3.14 0 6.095 1.22 8.316 3.441 2.222 2.22 3.44 5.176 3.44 8.317 0 6.479-5.289 11.76-11.77 11.76h-.008c-2.002 0-3.974-.537-5.708-1.554L0 24zm6.549-3.298c1.62.962 3.208 1.47 4.743 1.471 5.375 0 9.75-4.372 9.75-9.755 0-2.6-1.012-5.044-2.85-6.883C16.353 3.696 13.91 2.684 11.31 2.684c-5.378 0-9.754 4.374-9.755 9.757 0 1.637.491 3.238 1.42 4.67l-.98 3.58 3.69-.97c1.42.77 2.87 1.2 4.87 1.2zM17.3 14.86c-.33-.17-1.97-.97-2.28-1.08-.3-.11-.53-.17-.75.17-.22.33-.86 1.08-1.05 1.3-.2.22-.39.25-.72.08-1.74-.87-2.92-1.5-4.08-3.5-.3-.52-.3-.88-.13-1.05.15-.15.33-.39.5-.58.17-.2.22-.33.33-.56.11-.22.06-.42-.03-.58-.08-.17-.75-1.8-1.03-2.47-.27-.66-.55-.57-.75-.58H7.72c-.22 0-.58.08-.88.42-.3.33-1.15 1.13-1.15 2.75 0 1.62 1.18 3.19 1.35 3.42.17.22 2.33 3.56 5.65 5 1.58.68 2.81 1.09 3.77 1.4 1.6.5 3.06.43 4.2.26 1.28-.19 2.97-1.22 3.39-2.39.42-1.16.42-2.16.3-2.38-.13-.22-.45-.33-.78-.5z"/>
      </svg>
    </a>
  </body>
</html>
