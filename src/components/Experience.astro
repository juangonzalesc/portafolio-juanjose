---
interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;

const t = {
  es: {
    title: "Experiencia Máster",
    subtitle: "Trayectoria breve colaborando y coliderando el crecimiento orgánico de marcas comerciales.",
    experiences: [
      {
        company: "Brandlima",
        role: "Especialista en SEO y Marketing Digital",
        period: "2024 — Presente",
        current: true,
        description: "Liderazgo en optimización on-page, auditorías técnicas profundas y rediseño de arquitecturas web orientadas a la captación de tráfico calificado y conversión de negocio."
      },
      {
        company: "Rauletti Pastelería",
        role: "Digital Marketing Manager",
        period: "2022 — 2024",
        current: false,
        description: "Diseño y ejecución de la estrategia digital 360° y acuerdos comerciales clave para impulsar la expansión de marca a nivel regional."
      },
      {
        company: "Lovandi Joyería",
        role: "Marketing Manager",
        period: "2019 — 2022",
        current: false,
        description: "Construcción integral de la marca e-commerce desde cero, desarrollo de la plataforma web optimizada y despliegue de estrategias avanzadas de conversión de tráfico."
      }
    ]
  },
  en: {
    title: "Core Experience",
    subtitle: "A brief overview of collaborating and co-leading organic growth for commercial brands.",
    experiences: [
      {
        company: "Brandlima",
        role: "SEO & Digital Marketing Specialist",
        period: "2024 — Present",
        current: true,
        description: "Leadership in on-page optimization, deep technical audits, and redesign of web architectures oriented to capture qualified traffic and drive business conversion."
      },
      {
        company: "Rauletti Pastelería",
        role: "Digital Marketing Manager",
        period: "2022 — 2024",
        current: false,
        description: "Design and execution of 360° digital strategy and key commercial agreements to drive regional brand expansion."
      },
      {
        company: "Lovandi Joyería",
        role: "Marketing Manager",
        period: "2019 — 2022",
        current: false,
        description: "End-to-end building of the e-commerce brand from scratch, development of the optimized web platform, and deployment of advanced traffic conversion strategies."
      }
    ]
  }
}[lang];
---

<section id="trayectoria" class="experience-section">
  <div class="container">
    <!-- Header of the Section -->
    <div class="section-header">
      <h2 class="section-title">{t.title}</h2>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>

    <!-- Timeline Wrapper -->
    <div class="timeline-wrapper">
      {t.experiences.map((exp) => (
        <div class="timeline-item">
          <!-- Left column: Period -->
          <div class="timeline-meta">
            <span class={`timeline-period ${exp.current ? 'current-label' : ''}`}>
              {exp.period}
            </span>
          </div>
          
          <!-- Middle column: Node point -->
          <div class="timeline-node">
            <div class="node-dot"></div>
          </div>
          
          <!-- Right column: Content -->
          <div class="timeline-content">
            <h3 class="timeline-title">
              {exp.role} 
              <span class="timeline-company">at {exp.company}</span>
            </h3>
            <p class="timeline-desc">{exp.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience-section {
    position: relative;
    border-bottom: 1px solid var(--border-color);
    z-index: 10;
  }

  .section-header {
    margin-bottom: 3.5rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 1.5rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .section-count {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--text-muted);
    font-family: var(--font-sans);
    vertical-align: super;
    margin-left: 0.2rem;
  }

  .section-subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
  }

  /* Timeline Styles */
  .timeline-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Vertical line background */
  .timeline-wrapper::before {
    content: '';
    position: absolute;
    top: 15px;
    bottom: 15px;
    left: 200px;
    width: 1px;
    background-color: var(--border-color);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 200px 1px 1fr;
    gap: 30px;
    position: relative;
    padding-bottom: 3.5rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  /* Timeline meta (left) */
  .timeline-meta {
    text-align: right;
    padding-top: 4px;
  }

  .timeline-period {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--text-muted);
    font-family: var(--font-sans);
  }

  .timeline-period.current-label {
    color: #0883db;
  }

  /* Timeline Node (center) */
  .timeline-node {
    display: flex;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .node-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background-color: var(--border-color);
    border: 2px solid var(--bg-primary);
    position: absolute;
    top: 10px;
    left: -4px;
    transition: var(--transition-smooth);
  }

  .timeline-item:hover .node-dot {
    background-color: #0883db;
    box-shadow: 0 0 10px rgba(8, 131, 219, 0.6);
    transform: scale(1.3);
  }

  /* Timeline Content (right) */
  .timeline-content {
    padding-top: 0px;
  }

  .timeline-title {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .timeline-company {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--text-secondary);
    font-weight: 400;
    margin-left: 0.5rem;
  }

  .timeline-desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    font-weight: 300;
  }

  /* Responsive styling */
  @media (max-width: 768px) {
    .timeline-wrapper::before {
      left: 10px;
    }
    
    .timeline-item {
      grid-template-columns: 1fr;
      gap: 15px;
      padding-left: 30px;
      padding-bottom: 2.5rem;
    }

    .timeline-meta {
      text-align: left;
    }

    .timeline-node {
      position: absolute;
      left: 10px;
      top: 5px;
    }

    .node-dot {
      left: -4px;
    }
  }
</style>
